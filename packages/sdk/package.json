{
  "name": "@oasiz/sdk",
  "version": "1.5.4",
  "description": "Typed SDK for Oasiz game platform bridge APIs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepack": "npm run build",
    "test": "node --experimental-strip-types --test ./tests/**/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "tagFormat": "sdk-v${version}",
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "../../scripts/semantic-release/workspace-release.mjs",
        {
          "packageName": "@oasiz/sdk",
          "packagePath": "packages/sdk"
        }
      ],
      "@semantic-release/github",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "npm version ${nextRelease.version} --no-git-tag-version --allow-same-version --no-workspaces",
          "publishCmd": "npm publish --access public --no-workspaces"
        }
      ]
    ]
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "@types/node": "^25.3.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oasiz-ai/oasiz-tooling.git"
  }
}
